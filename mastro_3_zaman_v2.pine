//@version=5
indicator("mastro 3 Zaman (Refactored)", overlay=true, max_lines_count=500, max_labels_count=500)

// ============ USER INPUTS ============
tarihStr = input.string("2026-01-02", "Start Date")
linesForward = input.int(24, "Line forward bars", minval=1)
clearBeforeNew = input.bool(true, "Clear previous")

// ============ TIME INPUTS - EASY ADJUSTMENT ============
// GROUP 1 - 05:00 BLUE
SAAT_1 = input.int(5, "Time 1 - Hour", minval=0, maxval=23)
DAK_1 = input.int(0, "Time 1 - Minute", minval=0, maxval=59)

// GROUP 2 - 06:18 ORANGE
SAAT_2 = input.int(6, "Time 2 - Hour", minval=0, maxval=23)
DAK_2 = input.int(18, "Time 2 - Minute", minval=0, maxval=59)

// GROUP 3 - 16:18 GREEN
SAAT_3 = input.int(16, "Time 3 - Hour", minval=0, maxval=23)
DAK_3 = input.int(18, "Time 3 - Minute", minval=0, maxval=59)

// ============ HELPER FUNCTIONS ============
twoDigit(x) =>
    s = str.tostring(x)
    str.length(s) == 1 ? "0" + s : s

safeIntFromArray(arr, idx, defaultVal) =>
    not na(arr) and array.size(arr) > idx ? int(str.tonumber(array.get(arr, idx))) : defaultVal

// ============ DATE PARSING ============
tParts = str.split(tarihStr, "-")
nowYear = year(time)
nowMonth = month(time)
nowDay = dayofmonth(time)

yil = safeIntFromArray(tParts, 0, nowYear)
ay = safeIntFromArray(tParts, 1, nowMonth)
gun = safeIntFromArray(tParts, 2, nowDay)

// ============ TARGET TIMES GMT+3 ============
hedefZaman1 = timestamp("GMT+3", yil, ay, gun, SAAT_1, DAK_1)
hedefZaman2 = timestamp("GMT+3", yil, ay, gun, SAAT_2, DAK_2)
hedefZaman3 = timestamp("GMT+3", yil, ay, gun, SAAT_3, DAK_3)

// ============ TIME 1 - BLUE ============
var int target_bar_index_1 = na
var float target_high_1 = na
var float target_low_1 = na
var float fark_1 = na
var float e_1 = na
var float h1_1 = na
var float l1_1 = na
var line[] lines_arr_1 = array.new_line()
var label[] labels_arr_1 = array.new_label()

// ============ TIME 2 - ORANGE ============
var int target_bar_index_2 = na
var float target_high_2 = na
var float target_low_2 = na
var float fark_2 = na
var float e_2 = na
var float h1_2 = na
var float l1_2 = na
var line[] lines_arr_2 = array.new_line()
var label[] labels_arr_2 = array.new_label()

// ============ TIME 3 - GREEN ============
var int target_bar_index_3 = na
var float target_high_3 = na
var float target_low_3 = na
var float fark_3 = na
var float e_3 = na
var float h1_3 = na
var float l1_3 = na
var line[] lines_arr_3 = array.new_line()
var label[] labels_arr_3 = array.new_label()

// ============ TABLE ============
var table tablo = na
if na(tablo)
    tablo := table.new(position.top_right, 4, 5, border_width=1)
    table.cell(tablo, 0, 0, "", text_color=color.white, bgcolor=color.gray)
    table.cell(tablo, 1, 0, twoDigit(SAAT_1) + ":" + twoDigit(DAK_1), text_color=color.white, bgcolor=color.blue)
    table.cell(tablo, 2, 0, twoDigit(SAAT_2) + ":" + twoDigit(DAK_2), text_color=color.white, bgcolor=color.orange)
    table.cell(tablo, 3, 0, twoDigit(SAAT_3) + ":" + twoDigit(DAK_3), text_color=color.white, bgcolor=color.green)
    table.cell(tablo, 0, 1, "High", text_color=color.white, bgcolor=color.gray)
    table.cell(tablo, 0, 2, "Low", text_color=color.white, bgcolor=color.gray)
    table.cell(tablo, 0, 3, "H1", text_color=color.white, bgcolor=color.gray)
    table.cell(tablo, 0, 4, "L1", text_color=color.white, bgcolor=color.gray)

// ============ TARGET BAR DETECTION ============
isTargetBar1 = time >= hedefZaman1 and time[1] < hedefZaman1
isTargetBar2 = time >= hedefZaman2 and time[1] < hedefZaman2
isTargetBar3 = time >= hedefZaman3 and time[1] < hedefZaman3

// ============ HELPER FUNCTION - CLEAR AND CREATE LINES/LABELS ============
clearArray(linesArray, labelsArray) =>
    szL = array.size(linesArray)
    if szL > 0
        for i = 0 to szL - 1
            ln = array.get(linesArray, i)
            if not na(ln)
                line.delete(ln)
        array.clear(linesArray)
    szLb = array.size(labelsArray)
    if szLb > 0
        for i = 0 to szLb - 1
            lb = array.get(labelsArray, i)
            if not na(lb)
                label.delete(lb)
        array.clear(labelsArray)

// ============ TIME 1 - 05:00 BLUE ============
if isTargetBar1
    if clearBeforeNew
        clearArray(lines_arr_1, labels_arr_1)
    
    target_bar_index_1 := bar_index
    target_high_1 := high
    target_low_1 := low
    fark_1 := target_high_1 - target_low_1
    e_1 := fark_1 * 10.0
    h1_1 := target_low_1 + e_1
    l1_1 := target_high_1 - e_1
    
    ln_h = line.new(target_bar_index_1, target_high_1, target_bar_index_1 + linesForward, target_high_1, color=color.new(color.aqua, 0), style=line.style_dotted, width=2)
    ln_l = line.new(target_bar_index_1, target_low_1, target_bar_index_1 + linesForward, target_low_1, color=color.new(color.aqua, 0), style=line.style_dotted, width=2)
    array.push(lines_arr_1, ln_h)
    array.push(lines_arr_1, ln_l)
    
    ln_h1 = line.new(target_bar_index_1, h1_1, target_bar_index_1 + linesForward, h1_1, color=color.new(color.blue, 0), style=line.style_solid, width=2)
    ln_l1 = line.new(target_bar_index_1, l1_1, target_bar_index_1 + linesForward, l1_1, color=color.new(color.blue, 0), style=line.style_solid, width=2)
    array.push(lines_arr_1, ln_h1)
    array.push(lines_arr_1, ln_l1)
    
    lb_h = label.new(target_bar_index_1, target_high_1, "H-" + twoDigit(SAAT_1) + twoDigit(DAK_1), color=color.blue, textcolor=color.white, style=label.style_label_down, size=size.small)
    lb_l = label.new(target_bar_index_1, target_low_1, "L-" + twoDigit(SAAT_1) + twoDigit(DAK_1), color=color.blue, textcolor=color.white, style=label.style_label_up, size=size.small)
    lb_h1 = label.new(target_bar_index_1 + linesForward, h1_1, "H1-" + twoDigit(SAAT_1) + twoDigit(DAK_1), color=color.blue, textcolor=color.white, style=label.style_label_right, size=size.tiny)
    lb_l1 = label.new(target_bar_index_1 + linesForward, l1_1, "L1-" + twoDigit(SAAT_1) + twoDigit(DAK_1), color=color.blue, textcolor=color.white, style=label.style_label_right, size=size.tiny)
    array.push(labels_arr_1, lb_h)
    array.push(labels_arr_1, lb_l)
    array.push(labels_arr_1, lb_h1)
    array.push(labels_arr_1, lb_l1)
    
    table.cell(tablo, 1, 1, str.tostring(target_high_1, format.mintick), text_color=color.white, bgcolor=color.new(color.blue, 70))
    table.cell(tablo, 1, 2, str.tostring(target_low_1, format.mintick), text_color=color.white, bgcolor=color.new(color.blue, 70))
    table.cell(tablo, 1, 3, str.tostring(h1_1, format.mintick), text_color=color.white, bgcolor=color.new(color.blue, 70))
    table.cell(tablo, 1, 4, str.tostring(l1_1, format.mintick), text_color=color.white, bgcolor=color.new(color.blue, 70))

// ============ TIME 2 - 06:18 ORANGE ============
if isTargetBar2
    if clearBeforeNew
        clearArray(lines_arr_2, labels_arr_2)
    
    target_bar_index_2 := bar_index
    target_high_2 := high
    target_low_2 := low
    fark_2 := target_high_2 - target_low_2
    e_2 := fark_2 * 10.0
    h1_2 := target_low_2 + e_2
    l1_2 := target_high_2 - e_2
    
    ln_h = line.new(target_bar_index_2, target_high_2, target_bar_index_2 + linesForward, target_high_2, color=color.new(color.orange, 0), style=line.style_dotted, width=2)
    ln_l = line.new(target_bar_index_2, target_low_2, target_bar_index_2 + linesForward, target_low_2, color=color.new(color.orange, 0), style=line.style_dotted, width=2)
    array.push(lines_arr_2, ln_h)
    array.push(lines_arr_2, ln_l)
    
    ln_h1 = line.new(target_bar_index_2, h1_2, target_bar_index_2 + linesForward, h1_2, color=color.new(color.maroon, 0), style=line.style_solid, width=2)
    ln_l1 = line.new(target_bar_index_2, l1_2, target_bar_index_2 + linesForward, l1_2, color=color.new(color.maroon, 0), style=line.style_solid, width=2)
    array.push(lines_arr_2, ln_h1)
    array.push(lines_arr_2, ln_l1)
    
    lb_h = label.new(target_bar_index_2, target_high_2, "H-" + twoDigit(SAAT_2) + twoDigit(DAK_2), color=color.orange, textcolor=color.white, style=label.style_label_down, size=size.small)
    lb_l = label.new(target_bar_index_2, target_low_2, "L-" + twoDigit(SAAT_2) + twoDigit(DAK_2), color=color.orange, textcolor=color.white, style=label.style_label_up, size=size.small)
    lb_h1 = label.new(target_bar_index_2 + linesForward, h1_2, "H1-" + twoDigit(SAAT_2) + twoDigit(DAK_2), color=color.maroon, textcolor=color.white, style=label.style_label_right, size=size.tiny)
    lb_l1 = label.new(target_bar_index_2 + linesForward, l1_2, "L1-" + twoDigit(SAAT_2) + twoDigit(DAK_2), color=color.maroon, textcolor=color.white, style=label.style_label_right, size=size.tiny)
    array.push(labels_arr_2, lb_h)
    array.push(labels_arr_2, lb_l)
    array.push(labels_arr_2, lb_h1)
    array.push(labels_arr_2, lb_l1)
    
    table.cell(tablo, 2, 1, str.tostring(target_high_2, format.mintick), text_color=color.white, bgcolor=color.new(color.orange, 70))
    table.cell(tablo, 2, 2, str.tostring(target_low_2, format.mintick), text_color=color.white, bgcolor=color.new(color.orange, 70))
    table.cell(tablo, 2, 3, str.tostring(h1_2, format.mintick), text_color=color.white, bgcolor=color.new(color.orange, 70))
    table.cell(tablo, 2, 4, str.tostring(l1_2, format.mintick), text_color=color.white, bgcolor=color.new(color.orange, 70))

// ============ TIME 3 - 16:18 GREEN ============
if isTargetBar3
    if clearBeforeNew
        clearArray(lines_arr_3, labels_arr_3)
    
    target_bar_index_3 := bar_index
    target_high_3 := high
    target_low_3 := low
    fark_3 := target_high_3 - target_low_3
    e_3 := fark_3 * 10.0
    h1_3 := target_low_3 + e_3
    l1_3 := target_high_3 - e_3
    
    ln_h = line.new(target_bar_index_3, target_high_3, target_bar_index_3 + linesForward, target_high_3, color=color.new(color.lime, 0), style=line.style_dotted, width=2)
    ln_l = line.new(target_bar_index_3, target_low_3, target_bar_index_3 + linesForward, target_low_3, color=color.new(color.lime, 0), style=line.style_dotted, width=2)
    array.push(lines_arr_3, ln_h)
    array.push(lines_arr_3, ln_l)
    
    ln_h1 = line.new(target_bar_index_3, h1_3, target_bar_index_3 + linesForward, h1_3, color=color.new(color.green, 0), style=line.style_solid, width=2)
    ln_l1 = line.new(target_bar_index_3, l1_3, target_bar_index_3 + linesForward, l1_3, color=color.new(color.green, 0), style=line.style_solid, width=2)
    array.push(lines_arr_3, ln_h1)
    array.push(lines_arr_3, ln_l1)
    
    lb_h = label.new(target_bar_index_3, target_high_3, "H-" + twoDigit(SAAT_3) + twoDigit(DAK_3), color=color.green, textcolor=color.white, style=label.style_label_down, size=size.small)
    lb_l = label.new(target_bar_index_3, target_low_3, "L-" + twoDigit(SAAT_3) + twoDigit(DAK_3), color=color.green, textcolor=color.white, style=label.style_label_up, size=size.small)
    lb_h1 = label.new(target_bar_index_3 + linesForward, h1_3, "H1-" + twoDigit(SAAT_3) + twoDigit(DAK_3), color=color.green, textcolor=color.white, style=label.style_label_right, size=size.tiny)
    lb_l1 = label.new(target_bar_index_3 + linesForward, l1_3, "L1-" + twoDigit(SAAT_3) + twoDigit(DAK_3), color=color.green, textcolor=color.white, style=label.style_label_right, size=size.tiny)
    array.push(labels_arr_3, lb_h)
    array.push(labels_arr_3, lb_l)
    array.push(labels_arr_3, lb_h1)
    array.push(labels_arr_3, lb_l1)
    
    table.cell(tablo, 3, 1, str.tostring(target_high_3, format.mintick), text_color=color.white, bgcolor=color.new(color.green, 70))
    table.cell(tablo, 3, 2, str.tostring(target_low_3, format.mintick), text_color=color.white, bgcolor=color.new(color.green, 70))
    table.cell(tablo, 3, 3, str.tostring(h1_3, format.mintick), text_color=color.white, bgcolor=color.new(color.green, 70))
    table.cell(tablo, 3, 4, str.tostring(l1_3, format.mintick), text_color=color.white, bgcolor=color.new(color.green, 70))

// ============ PLOTS ============
plot(not na(h1_1) ? h1_1 : na, title="H1_" + twoDigit(SAAT_1) + twoDigit(DAK_1), linewidth=1, display=display.none, color=color.blue)
plot(not na(l1_1) ? l1_1 : na, title="L1_" + twoDigit(SAAT_1) + twoDigit(DAK_1), linewidth=1, display=display.none, color=color.blue)
plot(not na(h1_2) ? h1_2 : na, title="H1_" + twoDigit(SAAT_2) + twoDigit(DAK_2), linewidth=1, display=display.none, color=color.orange)
plot(not na(l1_2) ? l1_2 : na, title="L1_" + twoDigit(SAAT_2) + twoDigit(DAK_2), linewidth=1, display=display.none, color=color.orange)
plot(not na(h1_3) ? h1_3 : na, title="H1_" + twoDigit(SAAT_3) + twoDigit(DAK_3), linewidth=1, display=display.none, color=color.green)
plot(not na(l1_3) ? l1_3 : na, title="L1_" + twoDigit(SAAT_3) + twoDigit(DAK_3), linewidth=1, display=display.none, color=color.green)
